# === Dependencies ===
node_modules/
# covers backend/node_modules, frontend/node_modules, and root's own
# (e.g. @playwright/test) since git applies this pattern at every level

# === Environment files — never commit real secrets ===
.env
.env.local
.env.*.local
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*
*old_migration
# .env.example files are intentionally NOT ignored — they document required
# vars with placeholder values and belong in the repo

# === Next.js (backend/) ===
backend/.next/
backend/out/
backend/dist/
.vercel

# === Vite (frontend/) ===
frontend/dist/
frontend/dist-ssr/

# === Prisma ===
# Generated client output lives under node_modules by default and is
# already covered above. If you configured a custom `output` path in
# schema.prisma, add that path here explicitly — do NOT ignore
# prisma/migrations/, that's real, versioned schema history.

# === Playwright / e2e ===
test-results/
playwright-report/
blob-report/
playwright/.cache/

# === Build artifacts & TypeScript ===
*.tsbuildinfo
dist/
build/
coverage/

# === Logs ===
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# === OS files ===
.DS_Store
Thumbs.db

# === Editor / IDE ===
.vscode/*
!.vscode/extensions.json
.idea/

# === Docker ===
# Named volumes (e.g. pgdata) are managed by Docker itself, not the
# filesystem here, so there's nothing from docker-compose.yml to ignore
# by default — add entries here only if you introduce bind-mounted local
# data directories later.