{
  "name": "octrotus_solution_backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed:roles": "tsx lib/worker.ts",
    "seed:demo": "prisma db seed",
    "migrate": "prisma migrate dev", 

    "docker:build":"docker build -t acsono/document-workspace-local:latest",
    "docker:run":"docker run --name document-workspace-local --env-file .env -p 9000:9000 --restart unless-stopped acsono/document-workspace-local:latest",
    "docker:run:it":"docker run -it --rm --env-file .env -p 9000:9000 acsono/document_workspace:latest",

    "prod:migrate": "dotenv -e .env.production -- prisma migrate deploy", 
    "prod:seed": "dotenv -e .env.production -- prisma db seed",
    "prod:seed:roles":"dotenv -e .env.production -- tsx lib/worker.ts",

    "prod:docker:build":"docker build -t acsono/document-workspace-prod:latest",
    "prod:docker:run":"docker run --name document-workspace-prod --env-file .env.production -p 9000:9000 --restart unless-stopped acsono/document-workspace-prod:latest",
    "prod:docker:run:it":"docker run -it --rm --env-file .env.production -p 9000:9000 acsono/document_workspace-prod:latest"
  },
